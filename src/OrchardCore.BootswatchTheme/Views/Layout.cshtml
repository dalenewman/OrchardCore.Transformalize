@using OrchardCore.Admin.Models
@using OrchardCore.DisplayManagement
@using OrchardCore.DisplayManagement.ModelBinding
@using OrchardCore.Entities
@using OrchardCore.ResourceManagement
@using OrchardCore.Themes.Services
@using OrchardCore.Users.Models
@using OrchardCore.BootswatchTheme.Settings
@using OrchardCore.BootswatchTheme.Settings.Models
@using OrchardCore.Settings

@inject IDisplayManager<Navbar> DisplayManager
@inject IUpdateModelAccessor UpdateModelAccessor
@inject ThemeTogglerService ThemeTogglerService
@inject ISiteService SiteService
@inject IResourceManager ResourceManager
@using Microsoft.Extensions.Caching.Memory
@inject IMemoryCache MemoryCache
@inject OrchardCore.Environment.Cache.ISignal Signal
@{
    // Navbar is pre-rendered to allow resource injection.
    var navbar = await DisplayAsync(await DisplayManager.BuildDisplayAsync(UpdateModelAccessor.ModelUpdater));

    var bsTheme = await MemoryCache.GetOrCreateAsync(Constants.CacheKey, async entry => {
        entry.AddExpirationToken(Signal.GetToken(Constants.CacheKey));
        var site = await SiteService.GetSiteSettingsAsync();
        return site.As<BootswatchSettings>()?.Theme ?? "default";
    }) ?? "default";
    var useBootswatch = bsTheme != "default";

    if (useBootswatch)
    {
        // Suppress TheTheme's bundled stylesheet (which includes Bootstrap) so
        // the Bootswatch CDN version of Bootstrap takes precedence without doubling.
        // Layout styles normally provided by theme.css are restored via an inline
        // <style> block below.
        ResourceManager.NotRequired("stylesheet", "TheTheme");
    }
}
<!DOCTYPE html>
<html lang="@Orchard.CultureName()" dir="@Orchard.CultureDir()" data-bs-theme="@await ThemeTogglerService.CurrentTheme()" data-tenant="@ThemeTogglerService.CurrentTenant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@RenderTitleSegments(Site.SiteName, "before")</title>
    <link type="image/x-icon" rel="shortcut icon" href="~/TheTheme/images/favicon.ico">

    <!-- This script can't wait till the footer -->
    <script asp-name="theme-head" version="1" at="Head"></script>

    @if (useBootswatch)
    {
        <style asp-name="bootswatch-@bsTheme" at="Head"></style>
        <style>
            /* Restore layout rules that TheTheme's theme.css normally provides.
               These are intentionally kept in sync with TheTheme/Assets/scss/main/_layout.scss. */
            #togglePassword { width: 44px; padding: 0; }
            html { position: relative; min-height: 100%; }
            body { margin-bottom: 60px; }
            body > footer {
                position: absolute;
                bottom: 0;
                width: 100%;
                height: 60px;
                line-height: 60px;
            }
            html[data-bs-theme="light"] body > footer { background-color: #f5f5f5; }
            html[data-bs-theme="dark"]  body > footer { background-color: #343a40; }
            /* With the compact navbar (padding: 0) the navbar is ~32 px tall; 50 px
               gives comfortable clearance without the large gap of the default theme. */
            body > .container { padding: 50px 15px 0; }
        </style>
    }
    else if (Orchard.IsRightToLeft())
    {
        <style asp-name="bootstrap-rtl" version="5" at="Head"></style>
        <style asp-name="TheTheme" depends-on="bootstrap-rtl" asp-src="~/TheTheme/styles/theme.min.css" debug-src="~/TheTheme/styles/theme.css" at="Foot"></style>
    }
    else
    {
        <style asp-name="bootstrap" version="5" at="Head"></style>
        <style asp-name="TheTheme" depends-on="bootstrap" asp-src="~/TheTheme/styles/theme.min.css" debug-src="~/TheTheme/styles/theme.css" at="Foot"></style>
    }

    <script asp-name="bootstrap" version="5" at="Foot"></script>
    <script asp-name="theme-manager" at="Foot"></script>

    <script asp-name="font-awesome" at="Foot" version="6"></script>
    <resources type="Header" />
    <style>
        /* BootswatchTheme: compact navbar — removes Bootstrap's default vertical
           padding so the header takes less vertical space on every page.
           Must come after <resources type="Header" /> so it wins over
           Bootstrap/Bootswatch navbar padding rules flushed at that point. */
        .navbar { padding-top: 0; padding-bottom: 0; }
    </style>
    @await RenderSectionAsync("HeadMeta", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-md fixed-top @(useBootswatch ? "bg-primary navbar-dark" : "")">
        <div class="container">
            <shape type="Branding" />
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar" aria-expanded="false" aria-controls="navbar" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbar">
                <div class="d-flex w-100 align-items-center flex-column flex-md-row">
                    <menu alias="alias:main-menu" cache-id="main-menu" cache-fixed-duration="00:05:00" cache-tag="alias:main-menu" cache-context="user.roles" />
                    <div class="ms-md-auto">@navbar</div>
                </div>
            </div>
        </div>
    </nav>
    @await RenderSectionAsync("Header", required: false)
    <main class="container">
        @await RenderSectionAsync("Messages", required: false)
        @await RenderBodyAsync()
    </main>
    @if (IsSectionDefined("Footer"))
    {
        <footer>
            <div class="container">
                @await RenderSectionAsync("Footer", required: false)
            </div>
        </footer>
    }
    <resources type="FootScript" />
</body>
</html>
